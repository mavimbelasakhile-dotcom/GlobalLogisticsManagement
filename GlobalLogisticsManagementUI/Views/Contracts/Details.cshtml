@model GlobalLogisticsManagementUI.Models.ContractViewModel
@{
    ViewData["Title"] = "Contract Details";
}

<h2>Contract Details</h2>
<hr />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Contract #@Model.Id</h5>
        <span class="badge @GetStatusBadge(Model.Status) fs-6">@Model.StatusDisplay</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl>
                    <dt>Client</dt>
                    <dd>@(Model.Client?.Name ?? "N/A")</dd>

                    <dt>Service Level</dt>
                    <dd>@Model.ServiceLevel</dd>

                    <dt>Start Date</dt>
                    <dd>@Model.StartDate.ToString("yyyy-MM-dd")</dd>

                    <dt>End Date</dt>
                    <dd>@Model.EndDate.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <!-- Signed Agreement Section -->
                <div class="card bg-light border-0">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3">📄 Signed Agreement</h6>

                        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                        {
                            <div class="d-flex align-items-center mb-3">
                                <span class="badge bg-success me-2">Uploaded</span>
                                <small class="text-muted">@System.IO.Path.GetFileName(Model.SignedAgreementPath)</small>
                            </div>
                            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                                ⬇️ Download Agreement
                            </a>
                        }
                        else
                        {
                            <p class="text-muted mb-3">No signed agreement uploaded yet.</p>
                        }

                        <hr />
                        <form asp-action="Upload" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <div class="mb-2">
                                <label class="form-label small fw-semibold">Upload PDF Agreement</label>
                                <input type="file" name="file" class="form-control form-control-sm" accept=".pdf" required />
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">⬆️ Upload</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@functions {
    string GetStatusBadge(int status) => status switch
    {
        0 => "bg-secondary",
        1 => "bg-success",
        2 => "bg-danger",
        3 => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
