@model GlobalLogisticsManagementUI.Models.ContractViewModel
@{
    ViewData["Title"] = "Edit Contract";
    var clients = ViewBag.Clients as IEnumerable<GlobalLogisticsManagementUI.Models.ClientViewModel>;
}

<h2>Edit Contract</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="ClientId" class="form-label">Client</label>
                <select asp-for="ClientId" class="form-select" required>
                    @if (clients != null)
                    {
                        @foreach (var client in clients)
                        {
                            <option value="@client.Id" selected="@(client.Id == Model.ClientId)">@client.Name (@client.Region)</option>
                        }
                    }
                </select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ServiceLevel" class="form-label">Service Level</label>
                <select asp-for="ServiceLevel" class="form-select">
                    <option value="Standard">Standard</option>
                    <option value="Premium">Premium</option>
                    <option value="Enterprise">Enterprise</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-select">
                    <option value="0">Draft</option>
                    <option value="1">Active</option>
                    <option value="2">Expired</option>
                    <option value="3">On Hold</option>
                </select>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
