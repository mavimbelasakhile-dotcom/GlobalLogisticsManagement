@model GlobalLogisticsManagementUI.Models.ServiceRequestViewModel
@{
    ViewData["Title"] = "Service Request Details";
}

<h2>Service Request #@Model.Id</h2>
<hr />

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Service Request</h5>
        <span class="badge @GetStatusBadge(Model.Status) fs-6">@Model.StatusDisplay</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl>
                    <dt>Contract ID</dt>
                    <dd>@Model.ContractId</dd>

                    <dt>Description</dt>
                    <dd>@Model.Description</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl>
                    <dt>Cost (USD)</dt>
                    <dd>$@Model.CostUsd.ToString("F2")</dd>

                    <dt>Cost (ZAR)</dt>
                    <dd>R @Model.CostZar.ToString("F2")</dd>

                    <dt>Exchange Rate</dt>
                    <dd>@Model.ExchangeRate.ToString("F4")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@functions {
    string GetStatusBadge(int status) => status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-primary",
        2 => "bg-success",
        3 => "bg-danger",
        _ => "bg-secondary"
    };
}
