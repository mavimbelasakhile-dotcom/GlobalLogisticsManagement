@model GlobalLogisticsManagementUI.Models.ServiceRequestCreateViewModel
@{
    ViewData["Title"] = "Create Service Request";
    var contracts = ViewBag.Contracts as IEnumerable<GlobalLogisticsManagementUI.Models.ContractViewModel>;
}

<h2>Create Service Request</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="ContractId" class="form-label">Contract (Active Only)</label>
                <select asp-for="ContractId" class="form-select" required>
                    <option value="">-- Select Active Contract --</option>
                    @if (contracts != null)
                    {
                        @foreach (var contract in contracts)
                        {
                            <option value="@contract.Id">Contract #@contract.Id - @(contract.Client?.Name ?? "Unknown")</option>
                        }
                    }
                </select>
                <small class="text-muted">Only active contracts are available for service requests.</small>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="CostUsd" class="form-label">Cost (USD)</label>
                <input asp-for="CostUsd" type="number" step="0.01" class="form-control" required />
                <small class="text-muted">ZAR conversion will be calculated automatically via exchange rate API.</small>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
