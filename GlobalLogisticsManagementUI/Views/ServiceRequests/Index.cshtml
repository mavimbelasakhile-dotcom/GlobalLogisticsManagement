@model IEnumerable<GlobalLogisticsManagementUI.Models.ServiceRequestViewModel>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Service Requests</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Request</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Client</th>
                <th>Description</th>
                <th>Cost (USD)</th>
                <th>Cost (ZAR)</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.Id</td>
                    <td>@(request.Contract?.Client?.Name ?? "N/A")</td>
                    <td class="text-truncate" style="max-width: 300px;">@request.Description</td>
                    <td>$@request.CostUsd.ToString("F2")</td>
                    <td>R @request.CostZar.ToString("F2")</td>
                    <td>
                        <span class="badge @GetStatusBadge(request.Status)">@request.StatusDisplay</span>
                    </td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Details" asp-route-id="@request.Id" class="btn btn-sm btn-outline-info">View</a>
                        <form asp-action="Delete" asp-route-id="@request.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No service requests found. <a asp-action="Create">Create a new request</a>.
    </div>
}

@functions {
    string GetStatusBadge(int status) => status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-primary",
        2 => "bg-success",
        3 => "bg-danger",
        _ => "bg-secondary"
    };
}
