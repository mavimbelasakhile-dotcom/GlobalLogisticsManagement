@model GlobalLogisticsManagementUI.Models.ClientCreateViewModel
@{
    ViewData["Title"] = "Create Client";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h3 class="fw-bold"><i class="bi bi-person-plus me-2"></i>Add New Client</h3>
                <p class="text-muted mb-0">Register a new client in the logistics system</p>
            </div>
            <div class="card-body px-4 pb-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">
                            <i class="bi bi-building me-1"></i> Client Name
                        </label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Enter company or client name" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactDetails" class="form-label fw-semibold">
                            <i class="bi bi-envelope me-1"></i> Contact Details
                        </label>
                        <input asp-for="ContactDetails" class="form-control form-control-lg" placeholder="Email or phone number" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Region" class="form-label fw-semibold">
                            <i class="bi bi-geo-alt me-1"></i> Region
                        </label>
                        <input asp-for="Region" class="form-control form-control-lg" placeholder="e.g. Gauteng, Western Cape" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle me-1"></i> Create Client
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-x-circle me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
